{
  "$schema": "https://json.schemastore.org/claude-code-settings",
  "_comment": "Generated by SDD Framework. /sdd-doctor init tunes hooks to the detected stack.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/typecheck.py"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/lint.sh"
          }
        ]
      }
    ]
  }
}
