{
  "$schema": "https://json.schemastore.org/claude-code-settings",
  "_comment": "Generated by SDD plugin (/sdd-doctor init). ${PLUGIN_ROOT} is replaced with the absolute path to the installed plugin so hooks resolve correctly.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/typecheck.py"
          },
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT}/hooks/lint.sh"
          }
        ]
      }
    ]
  }
}
