#!/usr/bin/env bash
# Auto-generated by /sdd:doctor init — typecheck hook for {{TOOLS}}.
# Re-run /sdd:doctor init to regenerate, OR edit freely — init will skip a file that exists.
#
# ─────────────────────────────────────────────────────────────────────────────
# HOW DOCTOR USES THIS TEMPLATE (read me, then delete this block from the output):
#   1. Keep the header below (shebang → `ext=` line) verbatim.
#   2. Replace {{TOOLS}} with the comma-separated list of the typecheck tool(s) you wrote.
#   3. The three `case` blocks below are NOT a menu to pick from — they are WORKED EXAMPLES of
#      three recurring SHAPES. Write a block for whatever THIS project uses by copying the
#      closest shape and adapting it:
#        • tsc   — a runner-managed checker (probe the tool via the runner, then run it)
#        • mypy  — a direct on-PATH checker invoked per-file
#        • Java  — a compiler / build-tool task run via a repo-local wrapper (whole-module)
#      New languages/tools appear all the time; reproduce whatever this project runs to type-check.
#   4. End with the final `exit 0`.
# The contract for every block: gate on the file extension(s) the tool covers; no-op (`exit 0`)
# when the tool isn't runnable; on a real failure print to stderr and `exit 2` (which BLOCKS
# Claude). Prefer a per-file invocation; fall back to whole-project only for tools with no
# per-file mode (compilers, `tsc --noEmit`, `go vet`).
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

# Read the PostToolUse JSON payload from stdin and pull out tool_input.file_path.
file_path="$(cat | python3 -c 'import json,sys; print(json.load(sys.stdin).get("tool_input",{}).get("file_path",""))' 2>/dev/null || true)"
[[ -z "$file_path" ]] && exit 0
[[ ! -f "$file_path" ]] && exit 0

ext="${file_path##*.}"

# ── SHAPE: runner-managed checker (probe via runner, then run) ───────────────
# Example: tsc through npx. tsc has no per-file mode, so it checks the whole project.
case "$ext" in
  ts|tsx)
    command -v npx >/dev/null 2>&1 || exit 0
    npx --no-install --quiet tsc --version >/dev/null 2>&1 || exit 0   # tool absent → no-op
    if ! npx --no-install tsc --noEmit 2>&1; then
      echo "❌ tsc failed for $file_path" >&2
      exit 2
    fi
    ;;
esac

# ── SHAPE: direct on-PATH checker, invoked per-file ──────────────────────────
# Example: mypy. Same shape fits pyright, a per-file compiler front-end, etc.
case "$ext" in
  py)
    command -v mypy >/dev/null 2>&1 || exit 0
    if ! mypy "$file_path" 2>&1; then
      echo "❌ mypy failed for $file_path" >&2
      exit 2
    fi
    ;;
esac

# ── SHAPE: compiler / build-tool task via repo-local wrapper (whole-module) ──
# Example: Java — the compiler IS the type checker; no per-file mode, so compile the module.
# Same shape fits `cargo check`, `go vet ./...`, `dotnet build`, `deno check`, etc.
case "$ext" in
  java)
    if [[ -x ./gradlew ]]; then
      if ! ./gradlew -q compileJava 2>&1; then
        echo "❌ gradle compileJava failed for $file_path" >&2
        exit 2
      fi
    elif command -v gradle >/dev/null 2>&1 && { [[ -f build.gradle ]] || [[ -f build.gradle.kts ]]; }; then
      if ! gradle -q compileJava 2>&1; then
        echo "❌ gradle compileJava failed for $file_path" >&2
        exit 2
      fi
    elif command -v mvn >/dev/null 2>&1 && [[ -f pom.xml ]]; then
      if ! mvn -q compile 2>&1; then
        echo "❌ mvn compile failed for $file_path" >&2
        exit 2
      fi
    fi
    ;;
esac

exit 0
