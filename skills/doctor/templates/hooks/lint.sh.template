#!/usr/bin/env bash
# Auto-generated by /sdd:doctor init — lint hook for {{TOOLS}}.
# Re-run /sdd:doctor init to regenerate, OR edit freely — init will skip a file that exists.
#
# ─────────────────────────────────────────────────────────────────────────────
# HOW DOCTOR USES THIS TEMPLATE (read me, then delete this block from the output):
#   1. Keep the header below (shebang → `ext=` line) verbatim.
#   2. Replace {{TOOLS}} with the comma-separated list of the lint tool(s) you wrote.
#   3. The three `case` blocks below are NOT a menu to pick from — they are WORKED EXAMPLES of
#      three recurring SHAPES. Write a block for whatever linter THIS project configures by
#      copying the closest shape and adapting it:
#        • eslint — a runner-managed linter, probed then run PER-FILE
#        • ruff   — a direct on-PATH linter run per-file
#        • Java   — a linter run as a build-tool task via a repo-local wrapper
#      For one ecosystem there's usually exactly ONE linter (e.g. JS/TS: whichever of Biome /
#      ESLint / oxlint the project depends on). If the project configures NO linter, emit no lint
#      hook at all — don't invent one. New tools appear all the time; reproduce what this project uses.
#   4. End with the final `exit 0`.
# The contract for every block: gate on the file extension(s); no-op (`exit 0`) when the tool
# isn't runnable; on a real failure print to stderr and `exit 2` (BLOCKS Claude). Prefer running
# the linter on `$file_path` — this hook fires after every edit, so avoid whole-repo lint commands.
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

# Read the PostToolUse JSON payload from stdin and pull out tool_input.file_path.
file_path="$(cat | python3 -c 'import json,sys; print(json.load(sys.stdin).get("tool_input",{}).get("file_path",""))' 2>/dev/null || true)"
[[ -z "$file_path" ]] && exit 0
[[ ! -f "$file_path" ]] && exit 0

ext="${file_path##*.}"

# ── SHAPE: runner-managed linter (probe via runner, then run PER-FILE) ───────
# Example: ESLint through npx. Same shape fits Biome (`npx @biomejs/biome check`), oxlint, etc.
case "$ext" in
  ts|tsx|js|jsx|mjs|cjs)
    command -v npx >/dev/null 2>&1 || exit 0
    npx --no-install --quiet eslint --version >/dev/null 2>&1 || exit 0   # tool absent → no-op
    if ! npx --no-install eslint --max-warnings 0 "$file_path" 2>&1; then
      echo "❌ ESLint failed for $file_path" >&2
      exit 2
    fi
    ;;
esac

# ── SHAPE: direct on-PATH linter, invoked per-file ───────────────────────────
# Example: Ruff. Same shape fits rubocop (`bundle exec rubocop "$file_path"` — probe the gem
# first if run through bundler), clippy, golangci-lint, deno lint, etc.
case "$ext" in
  py)
    command -v ruff >/dev/null 2>&1 || exit 0
    if ! ruff check "$file_path" 2>&1; then
      echo "❌ Ruff failed for $file_path" >&2
      exit 2
    fi
    ;;
esac

# ── SHAPE: linter run as a build-tool task via repo-local wrapper ────────────
# Example: Java Checkstyle. Include ONLY when the project configures a Java linter; swap the
# task for `pmdMain` / `pmd:check` or `spotbugsMain` / `spotbugs:check` to match the project.
case "$ext" in
  java)
    if [[ -x ./gradlew ]]; then
      if ! ./gradlew -q checkstyleMain 2>&1; then
        echo "❌ gradle checkstyleMain failed for $file_path" >&2
        exit 2
      fi
    elif command -v mvn >/dev/null 2>&1 && [[ -f pom.xml ]]; then
      if ! mvn -q checkstyle:check 2>&1; then
        echo "❌ mvn checkstyle:check failed for $file_path" >&2
        exit 2
      fi
    fi
    ;;
esac

exit 0
